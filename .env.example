# Paystack public key — get yours free at https://paystack.com/za
# Test keys (pk_test_...) work without real charges
# Live keys (pk_live_...) require a verified Paystack business account
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# USD to ZAR conversion rate (FakeStore API returns USD prices)
# Update periodically to reflect current exchange rate
VITE_USD_TO_ZAR_RATE=18.5

# App name
VITE_APP_NAME=Kova

# FakeStore API base URL
VITE_API_BASE_URL=https://fakestoreapi.com
